# using  math.factorial()
import math
a=6;
print(math.factorial(a));

# Using NumPy's np.prod()
import numpy as np

n = 6
if n >= 0:
    print(np.prod(range(1, n+1)))  
else:
    print("Factorial is not defined for negative numbers")
    
#Using For Loop
n = 6
if n < 0:
    print("Factorial is not defined for negative numbers")
else:
    f = 1
    for i in range(1, n+1):
        f *= i
    print(f)
